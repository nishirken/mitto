{
  "name": "mitto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "build:apk:debug": "tsc && vite build && cap sync android && cd android && ./gradlew assembleDebug",
    "build:apk:release": "tsc && vite build && cap sync android && cd android && ./gradlew assembleRelease",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src/ && stylelint 'src/**/*.css'",
    "lint:fix": "eslint src/ --fix && stylelint 'src/**/*.css' --fix",
    "clean": "rm -rf dist android/app/build && cd android && ./gradlew clean",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --no-warn-ignored --fix",
    "src/**/*.css": "stylelint --fix"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@lit-labs/signals": "^0.2.0",
    "@lit/context": "^1.1.6",
    "lit": "^3.3.2",
    "signal-polyfill": "^0.2.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^10.0.1",
    "@open-wc/testing": "^4.0.0",
    "@originjs/vite-plugin-commonjs": "^1.0.3",
    "eslint": "^10.1.0",
    "happy-dom": "^20.8.4",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
