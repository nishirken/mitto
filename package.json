{
  "name": "mitto",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src/ && stylelint 'src/**/*.css'",
    "lint:fix": "eslint src/ --fix && stylelint 'src/**/*.css' --fix",
    "prepare": "simple-git-hooks",
    "postinstall": "mkdir -p public && cp node_modules/@dibgram/tdweb/dist/*.worker.js node_modules/@dibgram/tdweb/dist/*.wasm public/"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --fix",
    "src/**/*.css": "stylelint --fix"
  },
  "dependencies": {
    "@dibgram/tdweb": "^1.8.40",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@open-wc/testing": "^4.0.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "4.1.0",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.56.1",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
